# ──────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/memorycard"

# ──────────────────────────────────────────────────────────────
# IGDB / Twitch credentials
# https://dev.twitch.tv/console/apps
# ──────────────────────────────────────────────────────────────
IGDB_CLIENT_ID=""
IGDB_CLIENT_SECRET=""

# ──────────────────────────────────────────────────────────────
# OpenCritic (via RapidAPI) — optional
# Free tier: 25 requests/day
# 1. Sign up at https://rapidapi.com/auth/sign-up
# 2. Subscribe to "OpenCritic API" (free): https://rapidapi.com/opencriticapi/api/opencritic-api
# 3. Copy your X-RapidAPI-Key
# Leave blank to disable OpenCritic integration (app still works).
# ──────────────────────────────────────────────────────────────
OPENCRITIC_RAPIDAPI_KEY=""

# ──────────────────────────────────────────────────────────────
# Mode
# ──────────────────────────────────────────────────────────────
SINGLE_USER_MODE="true"
