# ──────────────────────────────────────────────────────────────
# Database — Railway sets this automatically when you attach Postgres
# Locally: postgresql://user:pass@localhost:5432/gamelog
# ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/gamelog"

# ──────────────────────────────────────────────────────────────
# IGDB / Twitch credentials
# Get them at https://dev.twitch.tv/console/apps
# ──────────────────────────────────────────────────────────────
IGDB_CLIENT_ID="your_twitch_app_client_id"
IGDB_CLIENT_SECRET="your_twitch_app_client_secret"

# ──────────────────────────────────────────────────────────────
# Mode
# "true" (default) → single user, no auth
# "false"          → multi user (NextAuth, not implemented yet)
# ──────────────────────────────────────────────────────────────
SINGLE_USER_MODE="true"
